# Backend runtime
PORT=5001
NODE_ENV=development

# PostgreSQL (required)
# Example:
# DATABASE_URL="postgresql://postgres:postgres@localhost:5432/citywater?schema=public"
DATABASE_URL=

# JWT
JWT_SECRET=replace-with-strong-secret
JWT_REFRESH_SECRET=replace-with-strong-refresh-secret
JWT_EXPIRES_IN=1h
JWT_REFRESH_EXPIRES_IN=7d

# Mail (required for OTP email flows)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=
EMAIL_PASS=
EMAIL_FROM="AquaConnect <no-reply@aquaconnect.local>"
